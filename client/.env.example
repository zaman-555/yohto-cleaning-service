# Copy this file to `.env.local` in this directory (Next.js loads `.env.local` automatically).

# Public API origin — required in production for browser requests (login, register).
# No trailing slash.
NEXT_PUBLIC_API_BASE_URL=https://yohto-cleaning-service.vercel.app

# Optional: server-only origin for SSR / Server Actions when the API is internal
# (e.g. http://api:5000 in Docker). If unset, server code uses NEXT_PUBLIC_API_BASE_URL.
# API_BASE_URL=https://yohto-cleaning-service.vercel.app
