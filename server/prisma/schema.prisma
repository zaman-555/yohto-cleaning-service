generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         Int      @id @default(autoincrement())
  name       String
  email      String   @unique
  password   String
  isApproved Boolean  @default(false)
  isAdmin    Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  tasks      Task[]
  refreshTokens RefreshToken[]
}

model Task {
  id            Int      @id @default(autoincrement())
  date          DateTime @db.Date
  shift         String
  userId        Int
  companyName   String
  task          String
  carName       String
  transportType String
  location      String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([date])
  @@map("task")
}

/// Weekly showcase cells. `rowKey` encodes placement, e.g. `2026-w18-1` (year, calendar week, row).
model TaskDetail {
  id        Int      @id @default(autoincrement())
  rowKey    String
  columnKey String
  date      DateTime
  text      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt @default(now())

  @@unique([rowKey, columnKey], map: "task_details_rowKey_columnKey_key")
  @@map("task_details")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    Int
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}
