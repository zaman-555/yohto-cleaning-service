DATABASE_URL="postgresql://user:password@localhost:5432/yohto_dashboard"
PORT=5000

# Required: at least 32 characters. Generate with: openssl rand -base64 48
JWT_SECRET="replace-with-a-long-random-secret-at-least-32-chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"
JWT_REFRESH_TTL_SECONDS="2592000"

# Next.js dev server origin (for CORS)
CLIENT_ORIGIN="http://localhost:3000"

# Number of reverse-proxy hops to trust for client IP (rate limiting).
# Use 1 behind a single proxy (Vercel/Render/Nginx); set 0 when running with no proxy.
TRUST_PROXY="1"

# Public base URL of the client, used to build links inside emails (e.g. password reset).
# Falls back to CLIENT_ORIGIN when unset.
CLIENT_BASE_URL="http://localhost:3000"

# Password reset
# Token lifetime in seconds (default 1800 = 30 minutes)
PASSWORD_RESET_TTL_SECONDS="1800"

# Resend (transactional email) — https://resend.com
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxx"
# Verified sender. For quick testing you can use Resend's sandbox: "Yohto <onboarding@resend.dev>"
EMAIL_FROM="Yohto Dashboard <onboarding@resend.dev>"

# Used by `npx prisma db seed`
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me-to-a-strong-password"
